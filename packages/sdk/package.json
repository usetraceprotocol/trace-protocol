{
  "name": "trace-protocol-sdk",
  "version": "0.4.0",
  "description": "Client SDK for querying Trace Protocol agent verdicts on Ethereum",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist", "README.md"],
  "repository": {
    "type": "git",
    "url": "https://github.com/traceprotocolscan/trace-protocol.git",
    "directory": "packages/sdk"
  },
  "homepage": "https://github.com/traceprotocolscan/trace-protocol#readme",
  "bugs": {
    "url": "https://github.com/traceprotocolscan/trace-protocol/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "undici": "^6.6.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vitest": "^1.2.1"
  },
  "license": "MIT",
  "keywords": ["ethereum", "ai-agent", "verification", "classification", "trace-protocol"]
}
